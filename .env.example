APP_ENV=dev
RUST_LOG=info

# mode: mock | paper | real
TRADING_MODE=mock

# dry run must be true by default
DRY_RUN=true

# Korea Investment Securities API
KIS_BASE_URL_MOCK=https://openapivts.koreainvestment.com:29443
KIS_BASE_URL_REAL=https://openapi.koreainvestment.com:9443
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
KIS_ACCOUNT_PRODUCT_CODE=01
KIS_ENABLE_REAL_ORDER=false

# Discord
DISCORD_WEBHOOK_URL=

# SQLite
DATABASE_URL=sqlite://data/kis_supply_bot.db

# Strategy
ENABLE_OPENING_STRATEGY=false
ENABLE_PULLBACK_STRATEGY=true
ENABLE_BREAKOUT_STRATEGY=true
MAX_DAILY_BUY_COUNT=3
MAX_POSITION_RATIO=0.10
MAX_DAILY_LOSS_RATE=-0.03
