app:
  env: dev
  trading_mode: mock
  dry_run: true

kis:
  base_url_mock: "https://openapivts.koreainvestment.com:29443"
  base_url_real: "https://openapi.koreainvestment.com:9443"
  app_key: ""
  app_secret: ""
  account_no: ""
  account_product_code: "01"
  enable_real_order: false

discord:
  webhook_url: ""

database:
  url: "sqlite://data/kis_supply_bot.db"

strategy:
  enable_opening_strategy: false
  enable_pullback_strategy: true
  enable_breakout_strategy: true

  lookback_days: 5
  min_institution_buy_days: 3
  min_foreign_buy_days: 3
  min_total_net_buy_amt_5d: 1000000000
  min_market_cap: 100000000000
  min_avg_trade_amount_20d: 5000000000
  max_rise_rate_5d: 0.20
  max_prev_day_rise_rate: 0.10

risk:
  max_daily_buy_count: 3
  max_position_ratio: 0.10
  max_daily_loss_rate: -0.03
  max_spread_rate: 0.003
  max_intraday_rise_rate: 0.07
  no_new_buy_after: "15:10:00"
  restrict_same_sector: false
